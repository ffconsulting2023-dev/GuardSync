{
  "name": "guardsync",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node-dev --respawn --transpile-only server.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && vite build && npm run obfuscate",
    "obfuscate": "javascript-obfuscator dist/server.js --output dist/server.js --compact true --string-array true --string-array-threshold 0.75 --identifier-names-generator hexadecimal --self-defending true",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@react-google-maps/api": "^2.20.8",
    "@tanstack/react-query": "^5.36.1",
    "@types/stripe": "^8.0.416",
    "@vitejs/plugin-react": "^4.2.1",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "recharts": "^2.12.6",
    "stripe": "^22.1.1",
    "uuid": "^14.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "javascript-obfuscator": "^4.1.1",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.0"
  }
}
