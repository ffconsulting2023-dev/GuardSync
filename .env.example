DATABASE_URL=postgresql://user:password@host:5432/guardsync
JWT_SECRET=your-jwt-secret-here
PORT=3000
NODE_ENV=development

# Google Vision API (FAX OCR)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# アプリURL（署名URL・承認URLの生成に使用）
APP_URL=https://guardsync.up.railway.app

# SendGrid / SMTP (メール送信)
SENDGRID_API_KEY=your-sendgrid-api-key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@guardsync.jp

# LINE Works
LINE_WORKS_CLIENT_ID=your-client-id
LINE_WORKS_CLIENT_SECRET=your-client-secret
LINE_WORKS_BOT_ID=your-bot-id
LINE_WORKS_CHANNEL_ID=your-channel-id

# TSA (タイムスタンプ認証局)
TSA_URL=http://timestamp.digicert.com

# Vite
VITE_API_URL=http://localhost:3000
