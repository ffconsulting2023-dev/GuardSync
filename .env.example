DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=<64文字以上のランダム文字列>
PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com
VITE_API_URL=https://your-domain.com
LINE_WORKS_BOT_ID=
LINE_WORKS_BOT_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
INBOUND_SECRET=<Webhook認証用シークレット>
INBOUND_COMPANY_CODE=<デフォルト受信会社コード>
ENCRYPTION_KEY=<32バイトのhex文字列（openssl rand -hex 32で生成）>
GOOGLE_MAPS_API_KEY=         # Google Maps API キー（Geocoding/Maps JavaScript API）
VITE_GOOGLE_MAPS_API_KEY=    # Google Maps JavaScript API キー（フロントエンド用）
