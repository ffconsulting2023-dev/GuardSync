DATABASE_URL=postgresql://user:password@host:5432/guardsync
JWT_SECRET=your-jwt-secret-here
PORT=3000
NODE_ENV=development

# Google Vision API (FAX OCR)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# SendGrid (メール送信)
SENDGRID_API_KEY=your-sendgrid-api-key

# LINE Works
LINE_WORKS_CLIENT_ID=your-client-id
LINE_WORKS_CLIENT_SECRET=your-client-secret
LINE_WORKS_BOT_ID=your-bot-id
LINE_WORKS_CHANNEL_ID=your-channel-id

# TSA (タイムスタンプ認証局)
TSA_URL=http://timestamp.digicert.com

# Vite
VITE_API_URL=http://localhost:3000
