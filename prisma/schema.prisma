generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// マルチテナント
// ─────────────────────────────────────────────

model Company {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique // 会社コード（ログイン用）
  plan        Plan     @default(MIN)
  isActive    Boolean  @default(true)
  isSuperAdmin Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── SaaS課金関連 ───
  stripeCustomerId    String?            @unique
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  planType            PlanType           @default(STARTER)
  trialEndsAt         DateTime?
  suspendedAt         DateTime?
  billingEmail        String?
  lastPaymentAt       DateTime?

  users         User[]
  guards        Guard[]
  clients       Client[]
  sites         Site[]
  contracts     Contract[]
  partners      Partner[]
  vehicles      Vehicle[]
  equipment     Equipment[]
  equipmentAssignments EquipmentAssignment[]
  schedules     Schedule[]
  attendances   Attendance[]
  invoices      Invoice[]
  dailyPayRequests DailyPayRequest[]
  eContracts    ElectronicContract[]
  notifications Notification[]
  autoReceipts  AutoReceipt[]
  invitations   Invitation[]
  lineWorksSettings LineWorksSettings?
  securityReports SecurityReport[]
  shiftSurveys    ShiftSurvey[]
  payrolls        Payroll[]
  subcontractorPayments SubcontractorPayment[]
  billingSubscriptions  BillingSubscription[]
  billingLogs           BillingLog[]
}

enum Plan {
  MIN
  MAX
}

model Invitation {
  id          String   @id @default(uuid())
  email       String
  token       String   @unique @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([companyId])
}

// ─────────────────────────────────────────────
// ユーザー（管理者・オペレーター）
// ─────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        UserRole @default(OPERATOR)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  isSuperAdmin Boolean @default(false)
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  passwordResetTokens  PasswordResetToken[]
  createdContracts     Contract[]
  createdInvoices      Invoice[]
  approvedDailyPays    DailyPayRequest[] @relation("ApprovedBy")
  eContractSignatures  EContractSignature[]

  @@index([companyId])
}

enum UserRole {
  SUPER_ADMIN   // 開発者（全テナント閲覧）
  ADMIN         // 会社管理者
  MANAGER       // 管理者（配員・請求）
  OPERATOR      // オペレーター（管制）
  VIEWER        // 閲覧のみ
}

// ─────────────────────────────────────────────
// 隊員（Guard）
// ─────────────────────────────────────────────

model Guard {
  id              String      @id @default(uuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  employeeNumber  String
  name            String
  nameKana        String
  birthDate       DateTime?
  gender          Gender?
  phone           String?
  email           String?
  address         String?
  certifications  String[]    // 警備業務検定等
  employmentType  EmploymentType @default(PART_TIME)
  bankAccount     Json?       // { bank, branch, type, number, holder }
  dailyPayEnabled Boolean     @default(false)
  dailyPayLimit   Int?        // 日払い1回の上限額（円）。null=制限なし
  dailyPayMonthlyLimit Int?   // 日払い月間上限額（円）。null=制限なし
  dailyPayFeeRate Float?      @default(0.03) // 日払い手数料率（デフォルト3%）
  lineWorksId     String?     // LINE Works メンバーID
  isActive        Boolean     @default(true)
  joinedAt        DateTime?
  leftAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // 住所（構造化）
  postalCode     String?
  prefecture     String?
  city           String?
  addressDetail  String?
  buildingName   String?
  lat            Float?    // 緯度（Google Geocoding で取得）
  lng            Float?    // 経度

  // 最寄駅
  nearestStation1 String?
  line1           String?
  nearestStation2 String?
  line2           String?

  // 追加属性
  birthplace     String?   // 本籍地
  medicalHistory String?   // 既往症
  financialIssues Boolean  @default(false)  // 金銭問題
  mbti           String?   // MBTI (ESTJ等)
  dormitory      String?   // 寮利用（寮名または null）
  guardClass     String?   // クラス（S/A/B/C）
  skills         String[]  // スキル（隊長、方交 等）
  nationality    String?   // 国籍
  notes          String?   // 備考

  // NG設定 (JSON配列)
  ngGuardIds     Json?  // [{id, name}]
  ngCompanies    Json?  // [{name}]
  ngConditions   String?

  // 評価
  overallRating  Int?      // 1-5
  ratingComment  String?
  chartRatings   Json?     // {customerComm, teamComm, leadership, trafficControl, attendance} 各1-5

  // 勤務希望条件
  workConditions Json?     // {daysPerWeek, annualSalary, maxHours, remarks}

  // 給与体系
  payType        String?   @default("DAY")  // DAY/MONTH/HOUR
  monthlyBase    Int?      // 基本給（月給の場合）
  hourlyBase     Int?      // 時給（時給の場合）

  // 勤務単価（日給・時給共通）
  dayShiftRate        Int?   // 日勤単価
  nightShiftRate      Int?   // 夜勤単価
  holidayDayRate      Int?   // 休日日勤単価
  holidayNightRate    Int?   // 休日夜勤単価
  dayOvertimeRate     Int?   // (日)残業単価
  nightOvertimeRate   Int?   // (夜)残業単価
  holidayDayOtRate    Int?   // (休日)残業単価
  holidayNightOtRate  Int?   // (休夜)残業単価

  // 手当
  positionAllowance   Int?  @default(0)  // 役職手当
  qualificationAllowance Int? @default(0) // 資格手当
  leaderAllowance     Int?  @default(0)  // 隊長手当
  joiningAllowance    Int?  @default(0)  // 入社手当
  otherAllowance1     Int?  @default(0)  // その他手当1
  otherAllowance2     Int?  @default(0)  // その他手当2
  otherAllowanceName1 String?  // その他手当1名称
  otherAllowanceName2 String?  // その他手当2名称

  // 社会保険
  employmentInsurance     Boolean @default(false)
  healthInsurance         Boolean @default(false)
  healthInsuranceGrade    Int?
  pensionInsurance        Boolean @default(false)
  pensionInsuranceGrade   Int?
  nursingInsurance        Boolean @default(false)  // 介護保険

  // 家族構成
  spouse          Boolean @default(false)  // 配偶者あり
  spouseDeduction Boolean @default(false)  // 配偶者控除
  dependents      Int     @default(0)      // 扶養人数

  // 緊急連絡先（構造化）
  emergencyName       String?
  emergencyKana       String?
  emergencyRelation   String?
  emergencyPostal     String?
  emergencyPrefecture String?
  emergencyCity       String?
  emergencyAddressDetail String?

  // 外国人就労管理
  residenceStatus       String?   // 在留資格（留学/技能実習/特定技能/永住者 等）
  residenceCardNumber   String?   // 在留カード番号
  residenceExpiry       DateTime? // 在留期限
  workPermitType        String?   // 資格外活動許可の種類（包括許可/個別許可）
  workPermitExpiry      DateTime? // 資格外活動許可期限
  weeklyHoursLimit      Int?      @default(28) // 就労時間上限（通常28h、長期休暇中40h）
  schoolName            String?   // 学校名（留学生の場合）
  schoolVacationStart   DateTime? // 長期休暇開始日
  schoolVacationEnd     DateTime? // 長期休暇終了日

  // 書類（構造化：true=提出済）
  docMyNumber         Boolean @default(false)
  docIdCard           Boolean @default(false)
  docIdentityCert     Boolean @default(false)
  docResidenceCard    Boolean @default(false)
  docResume           Boolean @default(false)
  docPledge           Boolean @default(false)
  docPhoto            Boolean @default(false)
  docOther            Boolean @default(false)
  docWorkPermit       Boolean @default(false)  // 資格外活動許可書

  myNumber          String?   // マイナンバー（AES-256暗号化して保存）
  myNumberUpdatedAt DateTime? // 最終更新日時

  schedules       Schedule[]
  attendances     Attendance[]
  dailyPayRequests DailyPayRequest[]
  securityReports SecurityReport[]
  shiftSurveyResponses ShiftSurveyResponse[]
  payrolls        Payroll[]

  // 相性関連
  compatibilitiesFrom GuardCompatibility[] @relation("CompatibilityFrom")
  compatibilitiesTo   GuardCompatibility[] @relation("CompatibilityTo")

  // 備品貸出
  equipmentAssignments EquipmentAssignment[]

  // 書類ファイル
  documents       GuardDocument[]

  @@unique([companyId, employeeNumber])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// 隊員相性（GuardCompatibility）
// ─────────────────────────────────────────────

model GuardCompatibility {
  id            String              @id @default(uuid())
  companyId     String
  guardId       String
  guard         Guard               @relation("CompatibilityFrom", fields: [guardId], references: [id])
  targetGuardId String
  targetGuard   Guard               @relation("CompatibilityTo", fields: [targetGuardId], references: [id])
  type          CompatibilityType   // GOOD=相性良好 / BAD=相性悪い / NG=配置不可
  reason        String?             // 理由メモ

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([guardId, targetGuardId])
  @@index([companyId])
  @@index([guardId])
  @@index([targetGuardId])
}

enum CompatibilityType {
  GOOD   // 相性良好（同じ現場に配置すると加点）
  BAD    // 相性悪い（同じ現場に配置すると減点）
  NG     // 配置不可（同じ現場に絶対配置しない）
}

// ─────────────────────────────────────────────
// 隊員書類ファイル（GuardDocument）
// ─────────────────────────────────────────────

model GuardDocument {
  id            String   @id @default(uuid())
  companyId     String
  guardId       String
  guard         Guard    @relation(fields: [guardId], references: [id])
  docType       String               // docMyNumber, docIdCard, docResume 等
  fileName      String               // 元ファイル名
  filePath      String               // サーバー上の保存パス
  fileSize      Int                  // バイト数
  mimeType      String               // application/pdf, image/jpeg 等
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([guardId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  FULL_TIME     // 正社員
  PART_TIME     // アルバイト・パート
  CONTRACT      // 契約社員
  DISPATCH      // 派遣
}

// ─────────────────────────────────────────────
// 取引先（Client）
// ─────────────────────────────────────────────

model Client {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  // ①基本情報
  clientCode    String?  // C00001
  name          String
  nameKana      String?
  category      ClientCategory @default(OTHER)
  positionTitle String?  // 代表役職
  contactName   String?  // 代表者名
  phone         String?  // 代表電話
  fax           String?  // FAX番号
  email         String?
  website       String?  // HP
  industry      String?  // 業種
  relationship  String?  // 関係性（依頼主/協力会社等）
  // 経理担当
  accountingContactName String?
  accountingPhone       String?
  accountingEmail       String?
  notes         String?

  // ②担当者（最大4名・JSON配列）
  // [{ name, phone, email }, ...]
  subContacts   Json?

  // ③会社住所（構造化）
  postalCode    String?
  prefecture    String?
  city          String?
  addressDetail String?
  buildingName  String?
  addressee     String?  // 宛名

  // ④請求先住所
  billingSameAsCompany Boolean @default(true)
  billingPostalCode    String?
  billingPrefecture    String?
  billingCity          String?
  billingAddressDetail String?
  billingBuildingName  String?
  billingAddressee     String?

  // ④書類チェック（JSON）
  // { unitPriceContract, otherContract, invoiceSend, invoiceReceive, securityLog, securityCommission, other }
  documents     Json?

  // ⑤振込先
  bankName          String?
  bankBranch        String?
  bankAccountType   String?  // 普通/当座
  bankAccountNumber String?
  bankAccountHolder String?

  // ⑥契約単価
  contractDate           DateTime?
  unitPriceDay           Int?
  unitPriceNight         Int?
  unitPriceHolidayDay    Int?
  unitPriceHolidayNight  Int?
  overtimeDayRate        Int?
  overtimeNightRate      Int?
  overtimeHolidayDayRate Int?
  overtimeHolidayNightRate Int?
  qualificationAllowance Int?
  radioAllowance         Int?
  otherAllowance1        Int?
  otherAllowance2        Int?

  // 旧フィールド（後方互換）
  address       String?
  invoiceRegistrationNumber String?

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sites       Site[]
  logs        ClientLog[]
  invoices    Invoice[]

  @@index([companyId])
}

model ClientLog {
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId     String
  logType       String   @default("NOTE") // NOTE/CALL/MEETING/EMAIL
  content       String
  createdByName String?
  createdAt     DateTime @default(now())

  @@index([clientId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// 現場（Site）
// ─────────────────────────────────────────────

model Site {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  name        String
  address     String
  lat         Float?
  lng         Float?
  clientName  String?  // 発注元名（clientId未設定時の手入力用）
  clientPhone String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  siteCode           String?  // 現場コード
  requiredCount      Int      @default(1)       // 必要隊員数
  requiredQualifiedA Int      @default(0)       // 資格者A必要数
  requiredQualifiedB Int      @default(0)       // 資格者B必要数
  assemblyTime       String?  // 集合時間 "08:00"
  defaultStartTime   String?  // 開始予定 "08:30"
  defaultEndTime     String?  // 終了予定 "17:30"
  assemblyPlace      String?  // 集合場所
  cautions           String?  // 注意点

  contracts   Contract[]
  schedules   Schedule[]
  securityReports SecurityReport[]
  equipmentAssignments EquipmentAssignment[]

  @@index([companyId])
  @@index([clientId])
}

// ─────────────────────────────────────────────
// 契約（Contract）
// ─────────────────────────────────────────────

model Contract {
  id            String         @id @default(uuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  siteId        String
  site          Site           @relation(fields: [siteId], references: [id])
  contractNumber String        @unique
  clientName    String        // スナップショット：契約作成時の取引先名（Site→Clientで最新値を参照可能）
  startDate     DateTime
  endDate       DateTime?
  // 契約単価（4区分）- SSOTの正はContract。Client.unitPrice* はデフォルト値の参照元
  unitPriceDay          Int?  // 日勤単価（円）
  unitPriceNight        Int?  // 夜勤単価（円）
  unitPriceHolidayDay   Int?  // 休日日勤単価（円）
  unitPriceHolidayNight Int?  // 休日夜勤単価（円）
  unitPrice     Int            // 旧単価フィールド（後方互換用。新規は unitPriceDay/Night を使用）
  guardCount    Int            @default(1)
  shiftPattern  Json?          // { start, end, breakMinutes }
  status        ContractStatus @default(ACTIVE)
  notes         String?
  createdById   String
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invoiceItems  InvoiceItem[]
  eContracts    ElectronicContract[]
  schedules     Schedule[]

  @@index([companyId])
  @@index([siteId])
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

// ─────────────────────────────────────────────
// 協力会社（Partner）
// ─────────────────────────────────────────────

model Partner {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  name        String
  type        PartnerType @default(GENERAL)
  contactName String?
  phone       String?
  email       String?
  priority    Int         @default(0) // 優先度（高いほど優先）
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  payments    SubcontractorPayment[]

  @@index([companyId])
}

enum PartnerType {
  GROUP      // グループ会社（最優先）
  PREFERRED  // 優先協力会社
  GENERAL    // 一般協力会社
}

// ─────────────────────────────────────────────
// 車両（Vehicle）
// ─────────────────────────────────────────────

model Vehicle {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  plateNumber String
  model       String?
  year        Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// ─────────────────────────────────────────────
// 備品管理（Equipment）
// ─────────────────────────────────────────────

model Equipment {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String               // 備品名（例: トランシーバー、誘導灯、ヘルメット）
  category        EquipmentCategory     // カテゴリ
  totalQuantity   Int                   // 会社保有数
  unitCost        Int?                  // 単価（円）
  manufacturer    String?               // メーカー名
  modelNumber     String?               // 型番
  notes           String?               // 備考
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments     EquipmentAssignment[]

  @@index([companyId])
}

enum EquipmentCategory {
  RADIO           // トランシーバー・無線機
  LIGHT           // 誘導灯・LED合図灯
  SAFETY          // ヘルメット・安全ベスト・安全靴
  SIGN            // コーン・バリケード・看板
  UNIFORM         // 制服・雨具
  VEHICLE_EQUIP   // 車載備品（発煙筒・三角表示板）
  OFFICE          // 事務用品（バインダー・報告書用紙）
  SIGNAGE         // サイネージ（電光掲示板・デジタル看板）
  OTHER           // その他
}

model EquipmentAssignment {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  equipmentId     String
  equipment       Equipment @relation(fields: [equipmentId], references: [id])
  assigneeType    AssigneeType          // GUARD=隊員貸出 / SITE=現場配備
  guardId         String?               // 隊員に貸出の場合
  guard           Guard?   @relation(fields: [guardId], references: [id])
  siteId          String?               // 現場に配備の場合
  site            Site?    @relation(fields: [siteId], references: [id])
  quantity        Int      @default(1)  // 数量
  assignedAt      DateTime @default(now()) // 貸出・配備日
  returnedAt      DateTime?             // 返却日（null=未返却）
  notes           String?               // 備考（シリアル番号等）

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([equipmentId])
  @@index([guardId])
  @@index([siteId])
}

enum AssigneeType {
  GUARD   // 隊員への貸出
  SITE    // 現場への配備
}

// ─────────────────────────────────────────────
// シフト・配員（Schedule）
// ─────────────────────────────────────────────

model Schedule {
  id          String         @id @default(uuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  guardId     String
  guard       Guard          @relation(fields: [guardId], references: [id])
  siteId      String
  site        Site           @relation(fields: [siteId], references: [id])
  date        DateTime       @db.Date
  startTime   String         // "09:00"
  endTime     String         // "17:00"
  status      ScheduleStatus @default(ASSIGNED)
  confirmedAt DateTime?      // 前日確認送信日時
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  shiftType      String   @default("DAY")  // DAY/NIGHT/DAY_AM/DAY_PM
  assemblyTime   String?  // 集合時間
  sentAt         DateTime?  // 送信日時
  contractId     String?  // FK to Contract（どの契約に基づくシフトか）
  contract       Contract? @relation(fields: [contractId], references: [id])

  attendance  Attendance?

  @@index([companyId, date])
  @@index([guardId, date])
  @@index([contractId])
}

enum ScheduleStatus {
  DRAFT       // 下書き
  ASSIGNED    // 配員済み
  CONFIRMED   // 隊員確認済み
  CANCELLED   // キャンセル
}

// ─────────────────────────────────────────────
// 出退勤（Attendance）
// ─────────────────────────────────────────────

model Attendance {
  id           String           @id @default(uuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id])
  guardId      String
  guard        Guard            @relation(fields: [guardId], references: [id])
  scheduleId   String           @unique
  schedule     Schedule         @relation(fields: [scheduleId], references: [id])
  clockInAt    DateTime?
  clockOutAt   DateTime?
  breakMinutes Int              @default(0)
  status       AttendanceStatus @default(PENDING)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  isHoliday          Boolean @default(false)  // 日・祝日フラグ
  earlyOvertimeMin   Int     @default(0)      // 早出残業（分）
  lateOvertimeMin    Int     @default(0)      // 遅出残業（分）
  transportAmount    Int     @default(0)      // 旅費
  otherAmount        Int     @default(0)      // その他手当

  @@index([companyId])
  @@index([guardId])
}

enum AttendanceStatus {
  PENDING     // 未打刻
  CLOCKED_IN  // 出勤済み
  COMPLETED   // 退勤済み
  ABSENT      // 欠勤
  LATE        // 遅刻
}

// ─────────────────────────────────────────────
// 請求（Invoice）
// ─────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  invoiceNumber String        @unique
  clientId      String?       // FK to Client（SSOTの正。clientName/clientEmail はスナップショット）
  client        Client?       @relation(fields: [clientId], references: [id])
  clientName    String        // スナップショット：発行時点の取引先名（法的文書用）
  clientEmail   String?       // スナップショット：発行時点のメールアドレス
  issueDate     DateTime      @db.Date
  dueDate       DateTime      @db.Date
  subtotal      Int
  taxRate       Float         @default(0.1)
  taxAmount     Int
  total         Int
  status        InvoiceStatus @default(DRAFT)
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         InvoiceItem[]

  @@index([companyId])
  @@index([status])
  @@index([clientId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id])
  description String
  quantity    Int
  unitPrice   Int
  amount      Int
  date        DateTime? @db.Date

  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// 日払い（DailyPay）
// ─────────────────────────────────────────────

model DailyPayRequest {
  id           String          @id @default(uuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id])
  guardId      String
  guard        Guard           @relation(fields: [guardId], references: [id])
  requestDate  DateTime        @db.Date
  amount       Int             // 申請金額
  feeRate      Float           @default(0.03) // 手数料率（3%等）
  feeAmount    Int             // 手数料
  netAmount    Int             // 振込額
  status       DailyPayStatus  @default(PENDING)
  approvedById String?
  approvedBy   User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  paidAt       DateTime?
  deductedAt   DateTime?       // 月末給与差引日
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([companyId])
  @@index([guardId])
  @@index([status])
}

enum DailyPayStatus {
  PENDING     // 申請中
  APPROVED    // 承認済み
  PAID        // 支払済み
  REJECTED    // 否認
  DEDUCTED    // 給与差引済み
}

// ─────────────────────────────────────────────
// 電子契約（ElectronicContract）
// ─────────────────────────────────────────────

model ElectronicContract {
  id              String          @id @default(uuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  contractId      String?
  contract        Contract?       @relation(fields: [contractId], references: [id])
  title           String
  content         String          // 契約文書テキスト
  pdfPath         String?         // 生成されたPDFパス
  status          EContractStatus @default(DRAFT)
  expiresAt       DateTime?       // 署名期限
  timestampToken  String?         // RFC3161 TSAトークン（Base64）
  timestampAt     DateTime?       // タイムスタンプ取得日時
  auditLog        Json[]          @default([]) // 操作ログ
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  signatures      EContractSignature[]

  @@index([companyId])
  @@index([contractId])
}

enum EContractStatus {
  DRAFT
  SENT       // 署名依頼送信済み
  PARTIALLY_SIGNED
  COMPLETED  // 全員署名済み
  EXPIRED
  CANCELLED
}

model EContractSignature {
  id              String     @id @default(uuid())
  eContractId     String
  eContract       ElectronicContract @relation(fields: [eContractId], references: [id], onDelete: Cascade)
  signerEmail     String
  signerName      String
  userId          String?
  user            User?      @relation(fields: [userId], references: [id])
  token           String     @unique @default(uuid()) // 署名URLトークン
  signedAt        DateTime?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime   @default(now())

  @@index([eContractId])
}

// ─────────────────────────────────────────────
// 警備報告書（SecurityReport）
// ─────────────────────────────────────────────

model SecurityReport {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  guardId     String
  guard       Guard    @relation(fields: [guardId], references: [id])
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  reportDate  DateTime @db.Date
  content     Json     // 報告内容（パトロール記録・特記事項等）
  approvalToken String? @unique @default(uuid()) // メールリンク承認用
  approvedAt  DateTime?
  approvedBy  String?
  pdfPath     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// LINE Works設定
// ─────────────────────────────────────────────

model LineWorksSettings {
  id            String   @id @default(uuid())
  companyId     String   @unique
  company       Company  @relation(fields: [companyId], references: [id])
  botId         String
  botSecret     String?
  channelId     String
  accessToken   String?
  tokenExpiresAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// 通知（Notification）
// ─────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  type        NotificationType
  title       String
  body        String
  targetId    String?          // 対象ID（guardId等）
  channel     String           @default("LINE_WORKS") // LINE_WORKS / EMAIL / BOTH
  sentAt      DateTime?
  status      String           @default("PENDING")
  createdAt   DateTime         @default(now())

  @@index([companyId])
  @@index([status])
}

enum NotificationType {
  DAY_BEFORE_CONFIRM  // 前日確認
  SHIFT_CHANGE        // シフト変更
  EMERGENCY           // 緊急連絡
  ANNOUNCEMENT        // お知らせ
  DAILY_PAY           // 日払い通知
}

// ─────────────────────────────────────────────
// 自動受付（AutoReceipt）- FAX/メール/LINE Works
// ─────────────────────────────────────────────

model AutoReceipt {
  id          String            @id @default(uuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])
  source      ReceiptSource
  rawContent  String            // OCR結果・メール本文等
  parsedData  Json?             // 解析済みデータ
  suggestion  Json?             // サジェスト（現場・日時・人数）
  status      ReceiptStatus     @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime          @default(now())

  @@index([companyId])
  @@index([status])
}

enum ReceiptSource {
  FAX
  EMAIL
  LINE_WORKS
}

enum ReceiptStatus {
  PENDING     // 未処理
  SUGGESTED   // サジェスト表示中
  ACCEPTED    // 受入済み（スケジュール登録）
  REJECTED    // 却下
}

// ─────────────────────────────────────────────
// シフトアンケート（ShiftSurvey）
// ─────────────────────────────────────────────

model ShiftSurvey {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  title         String
  // シフト種別定義 JSON: [{type:"DAY", label:"①日勤8:00-17:00", startTime:"08:00", endTime:"17:00"}]
  shiftTypes    Json
  startDate     DateTime @db.Date  // 対象期間開始
  endDate       DateTime @db.Date  // 対象期間終了
  answerStartAt DateTime
  answerEndAt   DateTime
  isExported    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  responses ShiftSurveyResponse[]
}

model ShiftSurveyResponse {
  id          String       @id @default(uuid())
  surveyId    String
  survey      ShiftSurvey  @relation(fields: [surveyId], references: [id])
  guardId     String
  guard       Guard        @relation(fields: [guardId], references: [id])
  companyId   String
  // answers JSON: [{date:"2025-04-14", shiftType:"DAY", available:true, note:""}]
  answers     Json
  submittedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([surveyId, guardId])
}

// ─────────────────────────────────────────────
// 給与明細（Payroll）
// ─────────────────────────────────────────────

model Payroll {
  id          String        @id @default(uuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  guardId     String
  guard       Guard         @relation(fields: [guardId], references: [id])
  year        Int
  month       Int           // 1-12
  status      PayrollStatus @default(DRAFT)

  // 勤怠サマリ
  workDays        Int @default(0)
  holidayWorkDays Int @default(0)
  totalWorkMinutes Int @default(0)
  regularMinutes  Int @default(0)
  overtimeMinutes Int @default(0)
  earlyOtMinutes  Int @default(0)
  lateOtMinutes   Int @default(0)
  paidLeaveDays   Int @default(0)
  absentDays      Int @default(0)

  // 支給
  basicPay          Int @default(0)
  overtimePay       Int @default(0)
  holidayPay        Int @default(0)
  positionAllowance Int @default(0)
  qualificationAllowance Int @default(0)
  leaderAllowance   Int @default(0)
  commuteAllowance  Int @default(0)
  travelExpense     Int @default(0)
  otherAllowance    Int @default(0)
  taxableTotal      Int @default(0)
  nonTaxableTotal   Int @default(0)
  grossPay          Int @default(0)

  // 控除
  healthInsurance   Int @default(0)
  pension           Int @default(0)
  employmentIns     Int @default(0)
  incomeTax         Int @default(0)
  residentTax       Int @default(0)
  otherDeduction    Int @default(0)
  totalDeduction    Int @default(0)

  // その他調整
  yearEndAdj        Int @default(0)
  netPay            Int @default(0)

  // 発行・送信
  issueDate   DateTime?
  sentAt      DateTime?
  confirmedAt DateTime?
  payDate     DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, guardId, year, month])
}

enum PayrollStatus {
  DRAFT       // 未入力
  IN_REVIEW   // 確認中
  CONFIRMED   // 確認済み
  PAID        // 支払済み
}

// ─────────────────────────────────────────────
// 支払管理（SubcontractorPayment）
// ─────────────────────────────────────────────

model SubcontractorPayment {
  id            String            @id @default(uuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id])
  partnerId     String?
  partner       Partner?          @relation(fields: [partnerId], references: [id])
  partnerName   String            // スナップショット：協力会社名（partnerId未設定の手入力対応のため保持）
  invoiceNumber String?
  year          Int
  month         Int
  status        SubPaymentStatus  @default(PENDING)
  clientName    String?           // 発注先
  siteNames     String?           // 現場名（カンマ区切り）
  periodStart   DateTime          @db.Date
  periodEnd     DateTime          @db.Date
  amount        Int               // 税込金額
  taxRate       Float             @default(0.1)
  notes         String?
  receivedAt    DateTime?         // 受領日
  paidAt        DateTime?         // 支払日

  // 明細 JSON: [{date, siteName, amount, count, qualifiedCount, unitPrice, qualifiedUnitPrice}]
  items         Json?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId])
  @@index([partnerId])
}

enum SubPaymentStatus {
  PENDING   // 未受領
  RECEIVED  // 受領済
  PAID      // 支払済
}

enum ClientCategory {
  GOVERNMENT    // 官公庁
  PRIVATE       // 民間企業
  CONSTRUCTION  // 建設・工事
  COMMERCIAL    // 商業施設
  INDIVIDUAL    // 個人
  OTHER         // その他
}

// ─────────────────────────────────────────────
// SaaS課金・サブスクリプション管理
// ─────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL      // 無料トライアル中
  ACTIVE     // 支払い済み・有効
  PAST_DUE   // 支払い遅延中（猶予期間内）
  SUSPENDED  // 利用停止
  CANCELLED  // 解約済み
}

enum PlanType {
  STARTER    // スターター（月額9,800円）
  STANDARD   // スタンダード（月額29,800円）
  ENTERPRISE // エンタープライズ（月額49,800円）
}

enum BillingLogType {
  PAYMENT_LINK_SENT       // Payment Link送付
  PAYMENT_SUCCEEDED       // 支払い成功
  PAYMENT_FAILED          // 支払い失敗
  SUBSCRIPTION_CREATED    // サブスクリプション作成
  SUBSCRIPTION_UPDATED    // サブスクリプション更新
  SUBSCRIPTION_CANCELLED  // サブスクリプション解約
  MANUAL_SUSPEND          // 手動停止
  MANUAL_REACTIVATE       // 手動再開
  AUTO_SUSPEND            // 自動停止
  REMINDER_SENT           // リマインドメール送付
}

model BillingSubscription {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  status               String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
}

model BillingLog {
  id                    String         @id @default(uuid())
  companyId             String
  company               Company        @relation(fields: [companyId], references: [id])
  stripeInvoiceId       String?        @unique
  stripePaymentIntentId String?
  type                  BillingLogType
  amount                Int            @default(0)
  currency              String         @default("jpy")
  description           String?
  metadata              Json?
  occurredAt            DateTime
  createdAt             DateTime       @default(now())

  @@index([companyId])
  @@index([occurredAt])
}

// ─────────────────────────────────────────────
// パスワードリセットトークン
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─────────────────────────────────────────────
// 給与マスタテーブル（年度更新対応）
// ─────────────────────────────────────────────

// 都道府県別健康保険等級表（協会けんぽ）
model HealthInsGradeTable {
  id               String @id @default(uuid())
  fiscalYear       Int    // 年度（例: 2026）
  prefecture       String // 都道府県名
  grade            Int    // 等級（1-50）
  standardMonthly  Int    // 標準報酬月額（円）
  employeeShare    Int    // 被保険者負担額（円）
  employerShare    Int    // 事業主負担額（円）
  nursingEmployee  Int    @default(0) // 介護保険被保険者負担額（円）※40歳以上
  nursingEmployer  Int    @default(0) // 介護保険事業主負担額（円）

  @@unique([fiscalYear, prefecture, grade])
  @@index([fiscalYear, prefecture])
}

// 厚生年金等級表（全32等級）
model PensionGradeTable {
  id               String @id @default(uuid())
  fiscalYear       Int
  grade            Int    // 等級（1-32）
  standardMonthly  Int    // 標準報酬月額（円）
  employeeShare    Int    // 被保険者負担額（円）
  employerShare    Int    // 事業主負担額（円）

  @@unique([fiscalYear, grade])
  @@index([fiscalYear])
}

// 雇用保険料率（事業種類別）
model EmploymentInsRate {
  id            String @id @default(uuid())
  fiscalYear    Int
  businessType  String // 一般/建設/農林水産
  employeeRate  Float  // 被保険者負担率（例: 0.006）
  employerRate  Float  // 事業主負担率（例: 0.0095）

  @@unique([fiscalYear, businessType])
  @@index([fiscalYear])
}

// 月額源泉徴収税額表（甲欄）
model IncomeTaxTable {
  id          String @id @default(uuid())
  fiscalYear  Int
  salaryFrom  Int    // 月額給与下限（円）
  salaryTo    Int    // 月額給与上限（円）
  dep0        Int    // 扶養0人の税額
  dep1        Int    // 扶養1人
  dep2        Int    // 扶養2人
  dep3        Int    // 扶養3人
  dep4        Int    // 扶養4人
  dep5        Int    // 扶養5人
  dep6        Int    // 扶養6人
  dep7        Int    // 扶養7人

  @@index([fiscalYear, salaryFrom])
}

// 住民税特別徴収（隊員別・月別）
model ResidentTax {
  id            String @id @default(uuid())
  companyId     String
  guardId       String
  fiscalYear    Int    // 年度
  month         Int    // 月（1-12）
  amount        Int    // 特別徴収額（円）
  municipality  String // 市区町村名

  @@unique([guardId, fiscalYear, month])
  @@index([companyId])
  @@index([guardId])
}

// 有給休暇管理
model PaidLeave {
  id          String   @id @default(uuid())
  companyId   String
  guardId     String
  grantDate   DateTime @db.Date // 付与日
  grantDays   Float    // 付与日数
  usedDays    Float    @default(0) // 使用日数
  expiryDate  DateTime @db.Date // 有効期限（付与日から2年）

  @@index([companyId])
  @@index([guardId])
}

// 賞与明細
model BonusPayroll {
  id               String   @id @default(uuid())
  companyId        String
  guardId          String
  paymentDate      DateTime @db.Date
  bonusType        String   // SUMMER/WINTER/OTHER
  grossAmount      Int      // 総支給額
  healthInsurance  Int      @default(0)
  pension          Int      @default(0)
  employmentIns    Int      @default(0)
  incomeTax        Int      @default(0) // 賞与用源泉徴収税
  otherDeduction   Int      @default(0)
  netAmount        Int      // 差引支給額
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([guardId])
}

// モジュール別アクセス権限
model ModulePermission {
  id       String  @id @default(uuid())
  userId   String
  module   String  // HR/ATTENDANCE/PAYROLL/INSURANCE/YEAREND/MYNUMBER/BONUS/TRANSFER
  canView  Boolean @default(false)
  canEdit  Boolean @default(false)
  canAdmin Boolean @default(false)

  @@unique([userId, module])
  @@index([userId])
}

// マイナンバー監査ログ
model MyNumberAuditLog {
  id          String   @id @default(uuid())
  companyId   String
  guardId     String
  userId      String   // アクセスしたユーザーID
  userName    String   // アクセスしたユーザー名
  action      String   // VIEW / UPDATE / DELETE
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([guardId])
  @@index([userId])
}

// 外国人就労時間アラートログ
model ForeignWorkerAlert {
  id          String   @id @default(uuid())
  companyId   String
  guardId     String
  weekStart   DateTime @db.Date // 週の開始日
  totalHours  Float    // その週の実労働時間
  limitHours  Int      // 上限時間（28 or 40）
  isVacation  Boolean  // 長期休暇中か
  alertType   String   // WARNING（超過間近）/ VIOLATION（超過）/ EXPIRY（期限切れ）
  message     String
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([guardId])
}
